# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only. Needed for cross-user / scheduled push sends
# (loading another user's subscriptions bypasses owner-only RLS). Self-sends
# work without it. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (M4-3) — generate with: npx web-push generate-vapid-keys
# Server-only secrets (must NOT be NEXT_PUBLIC_):
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Public VAPID key exposed to the browser for pushManager.subscribe().
# Must equal VAPID_PUBLIC_KEY.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Transactional email over SMTP. Free Gmail SMTP works and needs no domain.
# SMTP_PASSWORD must be a Google App Password (Account > Security > App passwords,
# requires 2-Step Verification) — NOT the Gmail account password.
# Host/port default to smtp.gmail.com / 465 (implicit TLS) when unset.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=
# Envelope From. Gmail rewrites this to SMTP_USER unless it's a verified alias.
EMAIL_FROM=Hifth Companion <you@gmail.com>
